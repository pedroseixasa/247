PORT=5000
MONGODB_URI=your_mongodb_connection_string
JWT_SECRET=your_secret_key_here

# Twilio SMS (Opcional - para enviar SMS de confirmação)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Resend Email (Obrigatório - 3000 emails/mês grátis)
# Obter API key em: https://resend.com/api-keys
# Ver setup completo em: RESEND_SETUP.md
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_EMAIL=admin@247barbearia.pt

NODE_ENV=development
CORS_ORIGIN=*
